--- /dev/null
+++ b/libgcc/config/i386/crti-adros.S
@@ -0,0 +1,14 @@
+/* crti.S for AdrOS — .init/.fini prologue */
+	.section .init
+	.global _init
+	.type _init, @function
+_init:
+	push %ebp
+	mov  %esp, %ebp
+
+	.section .fini
+	.global _fini
+	.type _fini, @function
+_fini:
+	push %ebp
+	mov  %esp, %ebp
--- /dev/null
+++ b/libgcc/config/i386/crtn-adros.S
@@ -0,0 +1,10 @@
+/* crtn.S for AdrOS — .init/.fini epilogue */
+	.section .init
+	pop %ebp
+	ret
+
+	.section .fini
+	pop %ebp
+	ret
+
+	.section .note.GNU-stack,"",@progbits
